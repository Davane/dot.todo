{
  "name": "dot-todo",
  "displayName": ".todo",
  "description": "Lightweight interactive editor for .todo plain-text files",
  "version": "0.1.0",
  "publisher": "dot-todo",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onCustomEditor:dot-todo.todoEditor"],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "dot-todo.todoEditor",
        "displayName": "Todo",
        "selector": [{ "filenamePattern": "*.todo" }],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  },
  "files": ["out", "src/webview/media"]
}
